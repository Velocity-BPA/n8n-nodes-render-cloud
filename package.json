{
  "name": "@velocity-bpa/n8n-nodes-render-cloud",
  "version": "1.0.0",
  "description": "n8n community node for Render Cloud platform - manage web services, databases, deployments and infrastructure",
  "keywords": [
    "n8n-community-node-package",
    "render",
    "cloud",
    "hosting",
    "deployment",
    "infrastructure"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://docs.n8n.io/integrations/community-nodes/",
  "author": {
    "name": "Velocity BPA",
    "email": "support@velocity-bpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-render-cloud.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RenderCloudApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RenderCloud/RenderCloud.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.15.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.3.2",
    "typescript": "~5.2.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}